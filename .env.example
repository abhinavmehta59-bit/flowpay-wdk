# FlowPay Environment Variables
# Copy this to .env and fill in your values

# Pimlico API Key for ERC-4337 bundler
PIMLICO_API_KEY=your_pimlico_key_here

# Agent Wallet Seed (12 words) - Generate a new one for production
AGENT_SEED=word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12

# Network: 'arbitrum' for mainnet, 'sepolia' for testnet
NETWORK=arbitrum

# Optional: WDK Indexer API Key for transaction history
# WDK_INDEXER_API_KEY=your_key_here

# Optional: MoonPay for fiat on-ramp
# MOONPAY_API_KEY=your_key_here
# MOONPAY_SECRET_KEY=your_secret_here